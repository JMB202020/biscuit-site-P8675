      <li><a href="/P8675" class="hover:text-[#FEC600] block py-1 transition-colors">Home</a></li>
      <li><a href="/P8675/aboutus-html" class="text-[#FEC600] block py-1">About Us</a></li>
      <li><a href="/P8675/thecattery-html" class="hover:text-[#FEC600] block py-1 transition-colors">The Cattery</a></li>
      <li><a href="/P8675/tariffandterms-html" class="hover:text-[#FEC600] block py-1 transition-colors">Tariff &amp; Terms</a></li>
      <li><a href="/P8675/contactus-html" class="hover:text-[#FEC600] block py-1 transition-colors">Contact Us</a></li>
