      <li><a href="/P8675/tariffandterms-html" class="hover:text-[#FEC600] transition-colors">Tariff &amp; Terms</a></li>
      <li><a href="/P8675/contactus-html" class="bg-[#FEC600] text-[#4C3B00] px-4 py-2 rounded-full hover:bg-[#CB9E00] transition-colors">Contact Us</a></li>
    </ul>
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
      <span class="block w-6 h-0.5 bg-white"></span>
      <span class="block w-6 h-0.5 bg-white"></span>
      <span class="block w-6 h-0.5 bg-white"></span>
