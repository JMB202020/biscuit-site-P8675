  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <a href="/P8675" class="font-display font-800 text-lg leading-tight">
      <span class="text-[#FEC600]">Worldham</span><br class="hidden sm:block" />
      <span class="text-white text-sm font-normal">Country Cattery</span>
    </a>
    <ul class="hidden md:flex items-center gap-6 text-sm font-semibold">
